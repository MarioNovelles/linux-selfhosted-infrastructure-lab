```gitignore
# -----------------------------------------------------------------------------
# Local notes / temporary files
# -----------------------------------------------------------------------------
FACTS_TO_FILL.md
*.bak
*.tmp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
# Real environment files must stay private.
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Secrets, keys, certificates, and private credentials
# -----------------------------------------------------------------------------
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx
*.jks
*.kdbx

id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

secrets/
private/

# -----------------------------------------------------------------------------
# Runtime application data
# -----------------------------------------------------------------------------
# Public examples should document the expected data paths,
# but real runtime data should not be committed.
data/
backups/
logs/

# -----------------------------------------------------------------------------
# Docker / Compose local override files
# -----------------------------------------------------------------------------
compose.override.yml
docker-compose.override.yml

# -----------------------------------------------------------------------------
# OS and editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
```

