# -----------------------------------------------------------------------------
# Local notes / temporary files
# -----------------------------------------------------------------------------
FACTS_TO_FILL.md
*.bak
*.tmp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
# Real environment files must stay private.
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Secrets, keys, certificates, and private credentials
# -----------------------------------------------------------------------------
*.key
*.pem
*.crt
*.csr
*.p12
*.pfx
*.jks
*.kdbx

id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

secrets/
private/

# -----------------------------------------------------------------------------
# Runtime application data
# -----------------------------------------------------------------------------
# Public examples should document the expected data paths,
# but real runtime data should not be committed.
data/
backups/
logs/
database/

# -----------------------------------------------------------------------------
# Local Docker Compose deployment files
# -----------------------------------------------------------------------------
# Public examples use compose.example.yml / compose.example.yaml.
# Real local deployments may copy these to compose.yml or compose.yaml.
compose.yml
compose.yaml
docker-compose.yml
docker-compose.yaml
compose.override.yml
compose.override.yaml
docker-compose.override.yml
docker-compose.override.yaml

# Keep public example Compose files tracked.
!compose.example.yml
!compose.example.yaml
!docker-compose.example.yml
!docker-compose.example.yaml

# -----------------------------------------------------------------------------
# OS and editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/

