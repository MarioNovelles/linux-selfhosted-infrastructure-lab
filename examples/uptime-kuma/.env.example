# Uptime Kuma example environment file
# Copy this file to .env before use:
# cp .env.example .env
# 
# -----------------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------------

TZ=Europe/Berlin

# -----------------------------------------------------------------------------
# Uptime Kuma web interface
# -----------------------------------------------------------------------------

# Bind to localhost by default to avoid direct network exposure.
# This avoids exposing the dashboard directly on all interfaces.
UPTIME_KUMA_BIND_ADDRESS=127.0.0.1

# Host port for Uptime Kuma
UPTIME_KUMA_PORT=3001

# -----------------------------------------------------------------------------
# MariaDB settings
# -----------------------------------------------------------------------------

# Database created during first MariaDB initialization.
MARIADB_DATABASE=uptime_kuma

# Application database user.
MARIADB_USER=uptime_kuma

# Replace in the real .env file.
MARIADB_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

# Replace in the real .env file.
MARIADB_ROOT_PASSWORD=CHANGE_ME_USE_A_DIFFERENT_LONG_RANDOM_PASSWORD
