# Traefik image version
TRAEFIK_VERSION=v3.7

# External Docker network shared by Traefik and routed containers
TRAEFIK_PROXY_NETWORK=proxy

# Local dashboard hostname
# Replace this in the real .env file.
TRAEFIK_DASHBOARD_HOST=traefik.lab.example.com

# Basic auth value for the Traefik dashboard.
#
# Generate a real value with:
#
# htpasswd -nbB admin "CHANGE_THIS_PASSWORD" | sed -e 's/\$/\$\$/g'
#
# Example shape only:
# TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$examplehash
#
# Do not commit the real generated value.
TRAEFIK_DASHBOARD_AUTH=admin:CHANGEME_GENERATED_HTPASSWD_HASH

# Traefik log level
TRAEFIK_LOG_LEVEL=INFO

# Future ACME / Cloudflare settings.
# These are not used in the local self-signed HTTPS step yet.
#
# LETSENCRYPT_EMAIL=admin@example.com
# CF_DNS_API_TOKEN=CHANGEME_CLOUDFLARE_DNS_TOKEN

